{
  "name": "inspect-canvas",
  "version": "0.1.0",
  "description": "Click any element in the browser, then tell your AI to update it",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "inspect-canvas": "dist/cli.js"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "tsc --noEmit"
  },
  "keywords": [
    "ui",
    "inspect",
    "preview",
    "ai",
    "design",
    "developer-tools"
  ],
  "license": "MIT",
  "author": "So Eun Ahn",
  "dependencies": {
    "express": "^5.2.1",
    "open": "^11.0.0"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@babel/generator": "^7.29.1",
    "@babel/parser": "^7.29.0",
    "@babel/plugin-syntax-jsx": "^7.28.6",
    "@babel/preset-typescript": "^7.28.5",
    "@babel/traverse": "^7.29.0",
    "@types/express": "^5.0.6",
    "@types/node": "^20.11.0",
    "tsup": "^8.0.0",
    "typescript": "^5.3.0",
    "vitest": "^4.1.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
